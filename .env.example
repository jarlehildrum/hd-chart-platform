# HD Platform Environment Variables
# Copy this file to .env and update the values

# Database
DATABASE_URL=Host=postgres;Port=5432;Database=hdplatform;Username=hduser;Password=hdplatform123
POSTGRES_DB=hdplatform
POSTGRES_USER=hduser
POSTGRES_PASSWORD=hdplatform123

# HD Platform API
HD_ADMIN_SECRET=hd_admin_536290824388ea22
ASPNETCORE_ENVIRONMENT=Production

# Stripe Configuration (REQUIRED for billing)
# Get these from https://dashboard.stripe.com/developers
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here
STRIPE_SUCCESS_URL=https://hdchartapi.com/success?session_id={CHECKOUT_SESSION_ID}
STRIPE_CANCEL_URL=https://hdchartapi.com/pricing
STRIPE_RETURN_URL=https://hdchartapi.com/account

# Grafana
GF_SECURITY_ADMIN_PASSWORD=hdplatform123

# Redis (optional)
REDIS_PASSWORD=hdplatform123

# SSL/Domain Configuration (for production)
DOMAIN_NAME=hdchartapi.com
CERTBOT_EMAIL=admin@hdchartapi.com

# Monitoring & Logs
LOG_LEVEL=Information
ENABLE_DETAILED_LOGGING=false

# Performance
MAX_REQUEST_SIZE=10MB
REQUEST_TIMEOUT=60